{
  "description": "Shamir Secret Sharing GF(256) test vectors. Irreducible polynomial: x^8+x^4+x^3+x+1 (0x11B). Threshold: 2, Total: 3.",
  "gf256_notes": {
    "polynomial": "0x11B",
    "multiply_by_2": "xtime(a) = (a < 0x80) ? (a << 1) : ((a << 1) ^ 0x1B)",
    "multiply_by_3": "gfMul(a, 3) = xtime(a) XOR a",
    "share_formula": "share[i] at x=n: secret[i] XOR gfMul(coeff[i], n)",
    "reconstruction": "Lagrange interpolation in GF(256); for 2-of-3: secret = gfMul(y1, gfMul(x2, inv(x1 XOR x2))) XOR gfMul(y2, gfMul(x1, inv(x1 XOR x2)))"
  },
