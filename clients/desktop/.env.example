# Sentry Error Tracking
# Get your DSN from https://sentry.io/settings/[org]/projects/[project]/keys/

# Frontend (React) - JavaScript project
VITE_SENTRY_DSN=
VITE_APP_VERSION=1.0.0

# Backend (Rust) - Rust project
SENTRY_DSN=

# Optional: Enable Sentry in development mode
# VITE_SENTRY_DEBUG=true

# OneSignal Push Notifications
# Get your App ID from https://onesignal.com
VITE_ONESIGNAL_APP_ID=
VITE_ONESIGNAL_SAFARI_WEB_ID=
