# SecureSharing (SSDID Edition) Development Environment Variables
# Copy this file to .env and adjust as needed
#
# Usage: cp .env.example .env

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL=ecto://securesharing:securesharing_dev@localhost:5433/securesharing_dev
DATABASE_POOL_SIZE=10

# =============================================================================
# Blob Storage (Garage - S3-Compatible)
# =============================================================================
# Garage is a lightweight, Rust-based S3-compatible storage
# Run: ./scripts/garage-init.sh after first docker-compose up

S3_ENDPOINT=http://localhost:3900
S3_ACCESS_KEY_ID=<run-garage-init-to-get-key>
S3_SECRET_ACCESS_KEY=<run-garage-init-to-get-secret>
S3_BUCKET=securesharing-dev
S3_REGION=garage

# =============================================================================
# SSDID — Self-Sovereign Distributed Identity
# =============================================================================
# Server identity password (used to protect the server's SSDID keypair)
SSDID_IDENTITY_PASSWORD=change_this_in_production

# SSDID Registry URL (DID Document resolution)
SSDID_REGISTRY_URL=https://registry.ssdid.my

# Cryptographic algorithm for server identity
# Options: ed25519, ecdsa_p256, ml_dsa_44, ml_dsa_65, kaz_sign
# SSDID_ALGORITHM=ed25519

# =============================================================================
# Application
# =============================================================================
SECRET_KEY_BASE=your-secret-key-base-generate-with-mix-phx-gen-secret
PHX_HOST=localhost
PHX_PORT=4000

# =============================================================================
# Email (Optional — notifications only, not for auth)
# =============================================================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@securesharing.local

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_UPLOADS_PER_HOUR=50

# =============================================================================
# Redis (Optional - for distributed setups)
# =============================================================================
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Clustering (Optional - for multi-node)
# =============================================================================
# CLUSTER_ENABLED=false
# NODE_NAME=securesharing@127.0.0.1
# CLUSTER_COOKIE=your-erlang-cookie
