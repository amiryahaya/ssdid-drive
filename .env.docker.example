# SecureSharing Docker Environment Configuration
# Copy this file to .env and adjust values as needed
#
# Usage:
#   cp .env.docker.example .env
#   docker-compose --profile pii up -d

# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_USER=securesharing
POSTGRES_PASSWORD=securesharing_dev
POSTGRES_DB=securesharing_dev
POSTGRES_PORT=5433

# =============================================================================
# Garage S3 Configuration
# =============================================================================
GARAGE_S3_PORT=3900
GARAGE_RPC_PORT=3901
GARAGE_WEB_PORT=3902
GARAGE_ADMIN_PORT=3903
# Garage access keys (set after running garage-init)
GARAGE_ACCESS_KEY_ID=
GARAGE_SECRET_ACCESS_KEY=

# =============================================================================
# Ollama Configuration
# =============================================================================
OLLAMA_PORT=11434
# Models are automatically pulled: phi3:mini, mistral:7b

# =============================================================================
# Presidio Configuration
# =============================================================================
PRESIDIO_PORT=5002

# =============================================================================
# Redis Configuration (distributed profile)
# =============================================================================
REDIS_PORT=6379

# =============================================================================
# MailHog Configuration (email profile)
# =============================================================================
MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8025

# =============================================================================
# PII Service Configuration (pii-service profile)
# =============================================================================
PII_SERVICE_PORT=4001
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=your-secret-key-base-here-at-least-64-bytes-long-for-security

# =============================================================================
# GPU Support (Linux with NVIDIA)
# =============================================================================
# Uncomment in docker-compose.yml to enable:
# - NVIDIA_VISIBLE_DEVICES=all
# - deploy.resources.reservations.devices
