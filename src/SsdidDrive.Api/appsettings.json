{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=ssdid_drive;Username=ssdid_drive;Password=ssdid_drive",
    "Redis": "localhost:6379"
  },
  "Ssdid": {
    "RegistryUrl": "https://registry.ssdid.my",
    "IdentityPath": "data/server-identity.json",
    "Algorithm": "KazSignVerificationKey2024",
    "PreviousIdentities": [],
    "Sessions": {
      "SessionTtlMinutes": 60,
      "ChallengeTtlMinutes": 5,
      "MaxSessions": 10000
    }
  },
  "Cors": {
    "Origins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:5174"
    ]
  }
}
