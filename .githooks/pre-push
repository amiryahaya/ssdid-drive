#!/usr/bin/env bash
# pre-push hook: Run CI checks for changed platforms before pushing.
# Mirrors the GitHub Actions workflows to catch failures locally.
#
# Checks which platforms have changes (vs the remote branch) and runs
# only the relevant builds/tests. Blocks push if any check fails.

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Get the range of commits being pushed
remote="$1"
url="$2"

# Read stdin for ref info
while read local_ref local_oid remote_ref remote_oid; do
    # Skip delete pushes
    if [ "$local_oid" = "0000000000000000000000000000000000000000" ]; then
        continue
    fi

    # Determine diff range
    if [ "$remote_oid" = "0000000000000000000000000000000000000000" ]; then
        # New branch вЂ” compare against main
        DIFF_BASE="origin/main"
    else
        DIFF_BASE="$remote_oid"
    fi

    # Get changed files
    CHANGED_FILES=$(git diff --name-only "$DIFF_BASE".."$local_oid" 2>/dev/null || git diff --name-only HEAD~5..HEAD)

    FAILED=0
    CHECKED=0

    # в”Ђв”Ђ Backend (.NET) в”Ђв”Ђ
    if echo "$CHANGED_FILES" | grep -qE '^src/SsdidDrive\.Api/|^tests/SsdidDrive\.Api\.Tests/'; then
        echo -e "${BLUE}[pre-push]${NC} Backend changes detected вЂ” building..."
        CHECKED=$((CHECKED + 1))
        if dotnet build src/SsdidDrive.Api -c Release --nologo -v q 2>&1 | tail -3; then
            echo -e "${GREEN}  вњ“ Backend build passed${NC}"
        else
            echo -e "${RED}  вњ— Backend build FAILED${NC}"
            FAILED=$((FAILED + 1))
        fi
    fi

    # в”Ђв”Ђ Android в”Ђв”Ђ
    if echo "$CHANGED_FILES" | grep -qE '^clients/android/'; then
        echo -e "${BLUE}[pre-push]${NC} Android changes detected вЂ” building..."
        CHECKED=$((CHECKED + 1))
        if (cd clients/android && ./gradlew assembleDevDebug --no-daemon -q 2>&1 | tail -3); then
            echo -e "${GREEN}  вњ“ Android build passed${NC}"
        else
            echo -e "${RED}  вњ— Android build FAILED${NC}"
            FAILED=$((FAILED + 1))
        fi
    fi

    # в”Ђв”Ђ Desktop (Tauri frontend) в”Ђв”Ђ
    if echo "$CHANGED_FILES" | grep -qE '^clients/desktop/src/'; then
        echo -e "${BLUE}[pre-push]${NC} Desktop changes detected вЂ” checking..."
        CHECKED=$((CHECKED + 1))
        if (cd clients/desktop && npm run typecheck 2>&1 | tail -3) && \
           (cd clients/desktop && npm run build 2>&1 | tail -3); then
            echo -e "${GREEN}  вњ“ Desktop typecheck + build passed${NC}"
        else
            echo -e "${RED}  вњ— Desktop checks FAILED${NC}"
            FAILED=$((FAILED + 1))
        fi
    fi

    # в”Ђв”Ђ Admin Portal в”Ђв”Ђ
    if echo "$CHANGED_FILES" | grep -qE '^clients/admin/'; then
        echo -e "${BLUE}[pre-push]${NC} Admin changes detected вЂ” checking..."
        CHECKED=$((CHECKED + 1))
        if (cd clients/admin && npm run build 2>&1 | tail -3); then
            echo -e "${GREEN}  вњ“ Admin build passed${NC}"
        else
            echo -e "${RED}  вњ— Admin build FAILED${NC}"
            FAILED=$((FAILED + 1))
        fi
    fi

    # в”Ђв”Ђ iOS (build check only on macOS) в”Ђв”Ђ
    if echo "$CHANGED_FILES" | grep -qE '^clients/ios/'; then
        if command -v xcodebuild &>/dev/null; then
            echo -e "${BLUE}[pre-push]${NC} iOS changes detected вЂ” skipped (use Xcode to verify)"
        else
            echo -e "${YELLOW}[pre-push]${NC} iOS changes detected вЂ” xcodebuild not available, skipped"
        fi
    fi

    # в”Ђв”Ђ CI Workflows в”Ђв”Ђ
    if echo "$CHANGED_FILES" | grep -qE '^\.github/workflows/'; then
        echo -e "${YELLOW}[pre-push]${NC} CI workflow changes detected вЂ” verify manually on GitHub"
    fi

    # в”Ђв”Ђ Summary в”Ђв”Ђ
    if [ $CHECKED -eq 0 ]; then
        echo -e "${GREEN}[pre-push]${NC} No platform changes detected вЂ” push allowed"
    elif [ $FAILED -gt 0 ]; then
        echo ""
        echo -e "${RED}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${NC}"
        echo -e "${RED}в•‘  PUSH BLOCKED: $FAILED of $CHECKED checks failed    в•‘${NC}"
        echo -e "${RED}в•‘  Fix the errors above before pushing.    в•‘${NC}"
        echo -e "${RED}в•‘                                          в•‘${NC}"
        echo -e "${RED}в•‘  To skip: git push --no-verify           в•‘${NC}"
        echo -e "${RED}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${NC}"
        exit 1
    else
        echo ""
        echo -e "${GREEN}[pre-push]${NC} All $CHECKED checks passed вњ“"
    fi
done

exit 0
