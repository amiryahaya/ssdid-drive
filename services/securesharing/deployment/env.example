# SecureSharing Environment Configuration
# Copy this file to /opt/securesharing/.env and configure

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# Database connection (PostgreSQL)
DATABASE_URL=ecto://securesharing:your_password_here@localhost/securesharing_prod

# Secret key for signing cookies and tokens (generate with: mix phx.gen.secret)
SECRET_KEY_BASE=your_64_character_secret_key_here

# Host configuration
PHX_HOST=your-domain.com
PORT=4000

# =============================================================================
# STORAGE SETTINGS
# =============================================================================

# Local file storage (default for single machine)
# Files will be stored in /var/lib/securesharing/uploads
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=/var/lib/securesharing/uploads

# S3 storage (optional - uncomment to use)
# STORAGE_PROVIDER=s3
# S3_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1

# =============================================================================
# DATABASE SETTINGS
# =============================================================================

# Connection pool size (adjust based on available memory)
POOL_SIZE=10

# Enable IPv6 for database connection (uncomment if needed)
# ECTO_IPV6=true

# =============================================================================
# CLUSTERING (Single Machine - Leave Disabled)
# =============================================================================

# For single machine deployment, clustering is not needed
# CLUSTER_STRATEGY=none

# =============================================================================
# RATE LIMITING
# =============================================================================

# For single machine, ETS backend is used by default (no Redis needed)
# Uncomment below to use Redis (for multi-node deployments)
# REDIS_URL=redis://localhost:6379

# =============================================================================
# EMAIL SETTINGS (Optional)
# =============================================================================

# SMTP Configuration
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your_username
# SMTP_PASSWORD=your_password
# SMTP_FROM_EMAIL=noreply@your-domain.com

# =============================================================================
# OBAN BACKGROUND JOBS
# =============================================================================

# Queue sizes (adjust based on workload)
OBAN_DEFAULT_QUEUE_SIZE=10
OBAN_MAILER_QUEUE_SIZE=5
OBAN_CLEANUP_QUEUE_SIZE=3
OBAN_STORAGE_QUEUE_SIZE=5
OBAN_MAINTENANCE_QUEUE_SIZE=2

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# PQC Algorithm suite (kaz, nist, or hybrid)
# DEFAULT_PQC_ALGORITHM=hybrid

# JWT token expiry (seconds)
# ACCESS_TOKEN_EXPIRY=900
# REFRESH_TOKEN_EXPIRY=604800

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug, info, warning, error
LOG_LEVEL=info

# =============================================================================
# SSL/TLS (Recommended for Production)
# =============================================================================

# For SSL termination at the app level (uncomment and configure)
# SSL_KEY_PATH=/etc/ssl/private/securesharing.key
# SSL_CERT_PATH=/etc/ssl/certs/securesharing.crt

# Or use a reverse proxy (nginx/caddy) for SSL termination (recommended)
